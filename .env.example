# GCP / GCS
GCP_PROJECT_ID=your-project-id
GCS_BUCKET=offsprint-docs

# Firebase Admin (service account)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=xxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Only set if your Firestore database isn't the default "(default)".
# e.g. if you named it "default" or something custom.
FIRESTORE_DATABASE_ID=(default)

# Firebase Web (public)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_APP_ID=

# Auth providers
# Enable Google and Microsoft sign-in providers in Firebase Console:
#   Firebase Console -> Authentication -> Sign-in method
#   - Google: enable (no extra config needed)
#   - Microsoft: enable, then provide Application (client) ID + secret from
#     Azure Portal -> App registrations. Add Firebase's OAuth redirect URI
#     (https://<auth-domain>/__/auth/handler) to the Azure app's redirect URIs.
#
# Optional: restrict Microsoft sign-in to a specific Azure AD tenant.
# Use the tenant ID (GUID), or one of: "common" (any account), "organizations"
# (work/school only), "consumers" (personal only). Leave empty for Firebase default.
NEXT_PUBLIC_MICROSOFT_TENANT=

# URLs
APP_BASE_URL=http://localhost:3000
USERCONTENT_BASE_URL=http://localhost:3001

# MiniMax (optional) — used to suggest human-readable slugs from content.
# Leave empty to fall back to random nanoid slugs.
MINIMAX_API_KEY=
# MiniMax-M2 is the fast non-thinking model; M2.7 is reasoning (slower, more expensive,
# and requires high max_tokens so we can pull the answer from reasoning_content).
MINIMAX_MODEL=MiniMax-M2
